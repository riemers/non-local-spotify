PORT=3000
BASE_URL=http://127.0.0.1:3000

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback
SESSION_SECRET=change-me-to-a-long-random-string

# Required for public deployment: gate the web UI and Spotify OAuth.
APP_ACCESS_PASSWORD=change-me-to-a-strong-password

# Required for public deployment: only this Spotify user ID may connect.
# Find yours after first login attempt in the error message, or via GET /v1/me while logged in.
ALLOWED_SPOTIFY_USER_ID=

# Persistent refresh token for daily cron (written after your first allowed login).
# Docker Compose uses /data inside the container; local dev can keep data/...
SPOTIFY_TOKEN_PATH=data/spotify-tokens.json

# In Docker: daily sync at 06:00 Europe/Amsterdam via supercronic (set false to disable).
ENABLE_CRON=true

# Chart source IDs to process, separated by commas.
CHART_SOURCES=top40-nl

# Optional: generated playlists are named "{chart source name}{suffix}".
TARGET_PLAYLIST_SUFFIX=" - NO NL"

# Optional: persistent Spotify Search cache. Mount this path as a volume on Coolify.
TRACK_CACHE_PATH=data/track-cache.json

# Optional: fail instead of waiting when Spotify returns a huge Retry-After.
SPOTIFY_MAX_RETRY_AFTER_SECONDS=60

# Optional: disable automatic artist genre and title detection.
AUTO_DETECT_DUTCH=true

# Optional env-based filter rules, comma-separated.
DUTCH_TRACK_IDS=
DUTCH_ARTISTS=
DUTCH_TITLE_WORDS=

# Available chart source IDs:
# kworb-nl-daily
# kworb-nl-daily-top-40
# kworb-nl-weekly
# kworb-nl-weekly-top-40
# top40-nl
# mega-single-top-100
# acharts-dutch-top-40
